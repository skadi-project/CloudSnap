<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime: разрешаем JIT (Electron V8 engine) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Hardened Runtime: разрешаем unsigned executable memory
         (нужно для Electron — V8 генерирует код на лету) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Hardened Runtime: разрешаем DYLD environment variables
         (нужно для electron-builder — использует DYLD для загрузки) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Screen Recording: macOS 10.15+ требует это разрешение
         для desktopCapturer (скриншоты и запись видео) -->
    <key>com.apple.security.screen-capture</key>
    <true/>

    <!-- Screen Recording: legacy-ключ для macOS 10.15–14.x -->
    <key>com.apple.security.device.screen-recording</key>
    <true/>

    <!-- Microphone/Audio: для записи системного звука -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Accessibility: для getWindowBounds() через JXA/AppleScript
         и для имитации ввода (hotkeys) -->
    <key>com.apple.security.automation.apple-script</key>
    <true/>
</dict>
</plist>
